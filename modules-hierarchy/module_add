module top_module(
    input [31:0] a,
    input [31:0] b,
    output [31:0] sum
);
	wire carry_out_lower; // intermediate wire to connect adders
    
    add16 low_adder (
        .a(a[15:0]),
        .b(b[15:0]),
        .cin(1'b0),
        .sum(sum[15:0]),
        .cout(carry_out_lower)
    );
    
    add16 high_adder (
        .a(a[31:16]),
        .b(b[31:16]),
        .cin(carry_out_lower),
        .sum(sum[31:16]),
        .cout()
    );
endmodule
